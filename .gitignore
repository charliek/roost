/mac/build/

# Phase 8: Linux .deb build staging + output
/dist/
/out/

# Sparkle EdDSA signing keys (issue #122) — NEVER commit. The private key lives
# only in the macOS login keychain and the SPARKLE_ED_PRIVATE_KEY repo secret.
# These patterns are a safety net for a key accidentally exported into the
# working tree (e.g. `generate_keys -x key.txt`).
sparkle*priv*.key
sparkle*private*
*sparkle*.key
*_ed25519
*_ed25519.key
sparkle_ed_key

# Local secrets (Developer ID cert + Apple creds) — never commit.
.secrets/

# Files below are git-ignored AND synced across machines via envsecrets
# (age-encrypted to GCS). Do not remove or modify the "# envsecrets" marker line;
# everything between it and the next blank line is the tracked-file list.
# envsecrets
.secrets/cert.p12
.secrets/apple.env

